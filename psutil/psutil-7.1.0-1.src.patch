+/*
+ * Map TCP state from /proc/net format to psutil constants
+ */
+static int
+map_tcp_state(unsigned int state)
+{
+    if (state < sizeof (tcp_state_map) / sizeof (tcp_state_map[0])) {
+        return tcp_state_map[state];
+    }
+    return PSUTIL_CONN_NONE;
+}
